meta {
  name: Readiness
  type: http
  seq: 2
}

get {
  url: {{BASE_URL}}/actuator/health/readiness
  body: none
  auth: inherit
}

docs {
  Public readiness probe intended for a container/orchestrator readiness check. Reports UP only when the app and the DB are healthy.
  Redis is intentionally excluded (informational only, in the full /actuator/health aggregate).
}
