# Ports exposed on the host
DB_HOST_PORT=5432
CACHE_HOST_PORT=6379
API_HOST_PORT=8080

# PostgreSQL
POSTGRES_USER=
POSTGRES_PASSWORD=

# Spring datasource password (can differ from POSTGRES_PASSWORD)
SPRING_DATASOURCE_PASSWORD=

# Redis
REDIS_PASSWORD=

# API security (SHA-256 hash of the API token — see docs/SECURITY.md)
API_TOKEN_HASH=

# Docker image tag (defaults to agrfesta/smart-home-api:1.0.0)
# APP_IMAGE_TAG=agrfesta/smart-home-api:1.0.0

# SwitchBot provider (optional — leave empty to disable)
PROVIDERS_SWITCHBOT_TOKEN=
PROVIDERS_SWITCHBOT_SECRET=

# Netatmo provider (optional — leave empty to disable)
PROVIDERS_NETATMO_CLIENTID=
PROVIDERS_NETATMO_CLIENTSECRET=
PROVIDERS_NETATMO_HOMEID=
PROVIDERS_NETATMO_ROOMID=
